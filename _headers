/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: cross-origin
  X-DNS-Prefetch-Control: off
  Content-Security-Policy: default-src 'self'; script-src 'self' https://cdn.jsdelivr.net https://apps.txid.uk https://www.googletagmanager.com https://gc.zgo.at https://api.txid.uk; connect-src 'self' https://api.txid.uk https://mempool.space https://txid.goatcounter.com https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com; style-src 'self' https://fonts.googleapis.com https://api.txid.uk https://apps.txid.uk; font-src https://fonts.gstatic.com; img-src 'self' data: https://api.txid.uk; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/sw.js
  Cache-Control: no-cache

/*.html
  Cache-Control: public, max-age=3600, must-revalidate

/images/*
  Cache-Control: public, max-age=604800

