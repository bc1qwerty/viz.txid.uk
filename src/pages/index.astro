---
// Root index — browser language detection with JS fallback
---

<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="robots" content="noindex">
  <link rel="canonical" href="https://viz.txid.uk/en/">
  <script is:inline>
    (function() {
      var saved = null;
      try { saved = localStorage.getItem('lang'); } catch(e) {}
      var lang = saved || (navigator.language || navigator.userLanguage || 'en').slice(0, 2);
      var supported = { ko: '/ko/', en: '/en/', ja: '/ja/' };
      var dest = supported[lang] || '/en/';
      // Preserve query params (e.g. ?tx=... or ?tab=mempool3d)
      if (window.location.search) dest += window.location.search;
      window.location.replace(dest);
    })();
  </script>
  <meta http-equiv="refresh" content="0;url=/en/">
  <title>Redirecting...</title>
</head>
<body>
  <p>Redirecting to <a href="/en/">Bitcoin Visualizer</a>...</p>
</body>
</html>
