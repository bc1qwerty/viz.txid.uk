---
import { sites } from '../data/sites';

interface Props {
  activeHost: string;
}

const { activeHost } = Astro.props;
---

<div class="appbar">
  {sites.map((site) => (
    <a href={site.url} class:list={{ active: site.host === activeHost }}>
      <svg width="18" height="18" class="icon-noshrink" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <Fragment set:html={site.icon} />
      </svg>
      <span data-ko={site.name.ko} data-en={site.name.en} data-ja={site.name.ja}>{site.name.ko}</span>
    </a>
  ))}
</div>
