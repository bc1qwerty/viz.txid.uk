---
interface Props {
  sub: string;
}

const { sub } = Astro.props;
---

<header>
  <div class="nav-top">
    <a href="https://txid.uk" class="logo" target="_blank" rel="noopener">
      <svg width="18" height="18" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="logo-icon" aria-hidden="true">
        <circle cx="20" cy="20" r="19" fill="#f7931a"/>
        <rect x="18.5" y="1" width="3" height="38" fill="#0d1117"/>
        <rect x="10" y="18.5" width="29" height="3" fill="#0d1117"/>
        <rect x="1" y="18.5" width="6" height="3" fill="#0d1117"/>
      </svg>txid.uk
    </a>
    <span class="logo-sep">/</span>
    <span class="logo-sub">{sub}</span>
    <div class="nav-links desktop-only">
      <a href="https://txid.uk/#/mining" data-ko="채굴" data-en="Mining" data-ja="マイニング">채굴</a>
      <a href="https://learn.txid.uk" target="_blank" data-ko="공부방" data-en="The Study" data-ja="学習室">공부방</a>
    </div>
    <div class="nav-right">
      <div id="txid-auth-mount" class="auth-mount"></div>
      <div class="lang-dropdown desktop-only">
        <button class="lang-btn" id="lang-btn" title="언어 변경" aria-label="언어 선택" aria-expanded="false">KO</button>
        <div class="lang-menu" id="lang-menu" role="menu" aria-label="언어 선택">
          <button>한국어</button>
          <button>English</button>
          <button>日本語</button>
        </div>
      </div>
      <button class="theme-btn desktop-only" id="theme-btn" title="테마 전환" aria-label="테마 전환"></button>
      <div class="hamburger-wrap mobile-only">
        <button class="theme-btn" id="hamburger-btn" aria-label="메뉴" aria-expanded="false">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <div class="hamburger-panel" id="hamburger-panel">
          <div class="settings-section">
            <div class="settings-label" data-ko="언어" data-en="Language" data-ja="言語">언어</div>
            <div class="settings-lang-row">
              <button class="settings-lang-btn" data-lang="ko">KO</button>
              <button class="settings-lang-btn" data-lang="en">EN</button>
              <button class="settings-lang-btn" data-lang="ja">JA</button>
            </div>
          </div>
          <div class="settings-section settings-section--border">
            <button class="settings-item" id="hamburger-theme-btn">
              <span id="hamburger-theme-icon"></span>
              <span id="hamburger-theme-label" data-ko="테마 전환" data-en="Toggle Theme" data-ja="テーマ切替">테마 전환</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
